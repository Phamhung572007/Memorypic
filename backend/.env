# Server
PORT=3000
JWT_SECRET=mysecret
CORS_ORIGIN=http://127.0.0.1:5500

API_PREFIX=/api

# Storage
# json: dung cac file trong C:\Memorypic\.json
# mongodb: dung database MongoDB da import bang Compass
STORAGE_MODE=mongodb

# MongoDB Compass / local MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=Memorypic

# (Optional) If you want to keep MySQL around temporarily
# DB_HOST=localhost
#DB_PORT=3306
#DB_USER=root
#DB_PASSWORD=123456
#DB_NAME=Memorypic

